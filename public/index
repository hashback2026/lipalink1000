<!DOCTYPE html>
<html>
<head>
  <title>STK Push Bot</title>
</head>
<body>
  <h2>Bulk STK Push</h2>

  <textarea id="numbers" rows="6" cols="40"
    placeholder="2547XXXXXXXX,2547XXXXXXXX"></textarea><br><br>

  <input type="number" id="amount" placeholder="Amount"><br><br>

  <button onclick="send()">Send STK</button>

  <pre id="output"></pre>

  <script>
    async function send() {
      const numbers = document.getElementById("numbers").value.split(",");
      const amount = document.getElementById("amount").value;

      const res = await fetch("/send-bulk", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ numbers, amount })
      });

      const data = await res.json();
      document.getElementById("output").innerText =
        JSON.stringify(data, null, 2);
    }
  </script>
</body>
</html>
